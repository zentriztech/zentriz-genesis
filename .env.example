# Variáveis de ambiente — copie para .env e preencha. O arquivo .env não é commitado (está no .gitignore).
# Lista completa e propósito de cada variável: project/docs/SECRETS_AND_ENV.md

# --- LLM / Agentes ---
# Provider: "anthropic" (API direta) ou "bedrock" (AWS Bedrock — recomendado se já usa AWS)
GENESIS_LLM_PROVIDER=bedrock

# Região AWS onde o Bedrock está habilitado (quando GENESIS_LLM_PROVIDER=bedrock)
# Credenciais AWS vêm do ambiente (AWS_PROFILE, IAM role, ~/.aws/credentials)
GENESIS_AWS_REGION=us-east-1

# Modelo — para Bedrock usar o inference profile ID com prefixo de região (ex: "us." para us-east-1)
CLAUDE_MODEL=us.anthropic.claude-sonnet-4-6

# não obrigatório quando GENESIS_LLM_PROVIDER=bedrock
# CLAUDE_API_KEY=your-claude-api-key-here

# --- Infra / Docker ---
# Namespace do projeto para containers, redes e volumes (local e k8s)
DOCKER_NAMESPACE=zentriz-genesis

# --- API (produto de exemplo) ---
# URL base da API para smoke tests e integrações (ex.: http://localhost:3000)
API_BASE_URL=http://localhost:3000

# --- Portal Genesis (genesis-web) ---
# Browser sempre faz fetch("/api/...") relativo. Next.js proxy /api/* → api:3000 (dev)
# ou nginx faz proxy (prod). NÃO defina NEXT_PUBLIC_API_BASE_URL — bundle vazaria URL.
# NEXT_INTERNAL_API_URL só é necessário se rodar Next.js FORA do Docker Compose
# (ex: pnpm dev direto no host). Default do next.config.mjs = "http://api:3000".

# --- Runtime dos agentes (Python) ---
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Timeout (s): runner→agents HTTP (recomendado 300; repair loop pode fazer 3 chamadas LLM) e cada chamada à Claude
REQUEST_TIMEOUT=300
# Retentativas do runner em caso de timeout ao chamar agents (default 2)
# AGENT_HTTP_RETRY_ON_TIMEOUT=2
# Exibir traceback completo nos erros do portal (true=dev, false=prod)
SHOW_TRACEBACK=true

# --- Agentes no host (contorna TLS no Docker Desktop Mac) ---
# Se o container não consegue TLS para api.anthropic.com, rode os agentes no host
# e descomente a linha abaixo. Depois rode: ./start-agents-host.sh
# API_AGENTS_URL=http://host.docker.internal:8000

# --- Pipeline (API → Runner) ---
# Opção A: comando para rodar o runner em subprocess (ex.: env PYTHONPATH=applications python -m orchestrator.runner)
# RUNNER_COMMAND=
# Opção B: URL do serviço runner (ex.: http://runner:8000)
# RUNNER_SERVICE_URL=
# Se definida, o runner chama os agentes via HTTP (ex.: http://agents:8000); senão usa import local
# API_AGENTS_URL=
# Pasta NO HOST onde os artefatos dos agentes serão salvos (bind mount → /project-files no container).
# Dentro do container PROJECT_FILES_ROOT é sempre /project-files (definido no docker-compose.yml).
# Se quiser usar uma pasta diferente, altere HOST_PROJECT_FILES_ROOT aqui.
HOST_PROJECT_FILES_ROOT=/Users/mac/zentriz-files
# Quando os agentes rodam NO HOST (./start-agents-host.sh), esta variável define onde gravar
# respostas da IA e artefatos (docs/cto/*.json, etc.). Se vazia, usa HOST_PROJECT_FILES_ROOT ou ~/zentriz-files.
PROJECT_FILES_ROOT=/Users/mac/zentriz-files
# Executar pipeline completo (Dev, QA, Monitor, DevOps) após PM Backend; false = só Engineer → CTO → PM Backend
PIPELINE_FULL_STACK=true
# Monitor Loop: intervalo em segundos entre ciclos (Fase 2) e máximo de reworks QA por tarefa (após N QA_FAIL a tarefa é marcada DONE)
# MONITOR_LOOP_INTERVAL=20
# MAX_QA_REWORK=3
# Rodadas máximas CTO↔Engineer e CTO↔PM (default 3 cada)
# MAX_CTO_ENGINEER_ROUNDS=3
# MAX_CTO_PM_ROUNDS=3

# --- Watchdog — Auto-recovery de projetos interrompidos ---
# O Watchdog detecta projetos com status 'running' na DB que não têm processo ativo no runner
# e os relança automaticamente, retomando do checkpoint salvo (LEI 11).
#
# Intervalo de verificação em millisegundos (padrão: 60000 = 1 minuto)
WATCHDOG_INTERVAL_MS=60000
# Máximo de restarts automáticos antes de desistir e marcar o projeto como 'failed'
# Evita loop infinito de projetos que sempre quebram no mesmo ponto
WATCHDOG_MAX_RESTARTS=5
# Tempo máximo de execução contínua em horas antes de forçar parada (proteção de custo)
# Projetos que rodam além desse limite são marcados como 'failed' com timed_out=true
WATCHDOG_MAX_RUNTIME_HOURS=8

# --- GitHub App (integração com repositórios dos tenants) ---
# Documentação: docs/01-ecosystem/federation/GITHUB_APP_INTEGRATION.md
#
# GITHUB_APP_ID
#   Número inteiro exibido na página da App após criação.
#   Onde encontrar: github.com/organizations/zentriztech/settings/apps/zentriz-autonomy → "App ID"
#   Exemplo: 123456
GITHUB_APP_ID=

# GITHUB_APP_CLIENT_ID
#   Identificador OAuth da App (começa com "Iv1.").
#   Onde encontrar: mesma página da App → "Client ID"
#   Exemplo: Iv1.abc123def456
GITHUB_APP_CLIENT_ID=

# GITHUB_APP_CLIENT_SECRET
#   Secret OAuth gerado ao clicar em "Generate a new client secret".
#   Onde encontrar: mesma página da App → botão "Generate a new client secret"
#   Atenção: exibido apenas uma vez — salve imediatamente.
GITHUB_APP_CLIENT_SECRET=

# GITHUB_APP_PRIVATE_KEY
#   Conteúdo completo do arquivo .pem gerado na seção "Private keys" da App.
#   Onde encontrar: página da App → "Private keys" → "Generate a private key" → arquivo baixado automaticamente
#   Para Docker/produção, prefira GITHUB_APP_PRIVATE_KEY_FILE apontando para o arquivo montado.
#   Formato: string multi-linha entre aspas, ou path para arquivo com GITHUB_APP_PRIVATE_KEY_FILE
#   Exemplo inline:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# GITHUB_APP_PRIVATE_KEY_FILE (alternativa ao inline acima — recomendado para Docker)
#   Path para o arquivo .pem dentro do container (monte via volume).
#   Exemplo: /run/secrets/github-app-private-key.pem
# GITHUB_APP_PRIVATE_KEY_FILE=

# ENCRYPTION_KEY — chave AES-256-CBC para cifrar credenciais por tenant (FT-12, FT-13)
#   OBRIGATÓRIO para FT-12 (GitHub App por tenant) e FT-13 (credenciais LLM por tenant).
#   Gerar uma chave aleatória segura: openssl rand -hex 32
#   NUNCA commitar o valor real — usar secret manager em produção.
#   Deve ser exatamente 64 caracteres hexadecimais (32 bytes).
ENCRYPTION_KEY=

# --- Telegram Bot (FT-09) ---
# Documentação: project/docs/TELEGRAM_SETUP.md
#
# TELEGRAM_BOT_TOKEN
#   Token do bot gerado pelo @BotFather. NUNCA commitar.
#   Onde obter: t.me/BotFather → /newbot → copiar token
TELEGRAM_BOT_TOKEN=

# TELEGRAM_WEBHOOK_SECRET
#   UUID aleatório para validar que requests vêm do Telegram (header X-Telegram-Bot-Api-Secret-Token).
#   Gerar: python3 -c "import uuid; print(uuid.uuid4())"
TELEGRAM_WEBHOOK_SECRET=

# TELEGRAM_WEBHOOK_PATH
#   Path não-previsível do endpoint de webhook (não usar /webhook ou /telegram diretamente).
#   Gerar: python3 -c "import uuid; print('wh/' + str(uuid.uuid4()))"
#   Exemplo: wh/a3f8c2d1-7b4e-4f9a-8c3d-2e1f5a6b7c8d
TELEGRAM_WEBHOOK_PATH=wh/change-me

# --- CAG / RAG (FT-RAG) ---
# Context-Aware Generation (CAG): injeta contratos Connect, checklists de bugs e
# lições quentes no SYSTEM_PROMPT antes de chamar o LLM. Modos:
#   off    — desligado (comportamento legado, padrão seguro)
#   shadow — popula cache mas NÃO injeta no prompt (somente observabilidade)
#   live   — popula cache E injeta no prompt
CAG_ENABLED=off

# RAG sobre o corpus de lições (lessons_corpus + lessons_embeddings com pgvector).
# Quando "live", o ContextLoader híbrido adiciona lições semanticamente próximas.
# Requer migration 026 e modelo de embedding disponível.
RAG_ENABLED=off

# Modo estrito de redação de PII em logs e corpus. true = falha-fechada.
PII_REDACTION_STRICT=true

# Mantém o caminho legado de carregamento de SYSTEM_PROMPT estático sempre disponível
# como fallback. NUNCA desligar em produção sem auditoria completa.
LEGACY_PROMPT_FALLBACK=true

# Modelo de embedding usado para RAG. all-MiniLM-L6-v2 = 384 dim, leve, multilíngue.
# Outros: BAAI/bge-small-en-v1.5 (384), intfloat/multilingual-e5-small (384).
EMBED_MODEL_ID=all-MiniLM-L6-v2

# Versão pinada do schema Connect consumido pelo ContextLoader.
# Bumps de Connect requerem revisão de compatibilidade antes de promover aqui.
CONNECT_VERSION_PIN=1.1.0

# --- FT-17 S3 Static Deploy ---
# IAM user dedicado (não usar AKID compartilhado do Bedrock/ECR).
# Setar via aws iam create-user genesis-s3-deployer + policy GenesisS3DeployerPolicy.
AWS_S3_DEPLOY_ACCESS_KEY_ID=
AWS_S3_DEPLOY_SECRET_ACCESS_KEY=
AWS_S3_DEPLOY_REGION=us-east-1
S3_STATIC_BUCKET_PREFIX=genesis
S3_STATIC_TTL_DAYS=7
S3_STATIC_MAX_SIZE_MB=50
S3_STATIC_RATE_LIMIT_PER_HOUR=3
S3_STATIC_MAX_ACTIVE_PER_TENANT=5
