# Zentriz Genesis — exemplo de configuração
# Copie para terraform.tfvars e preencha. NÃO commitar terraform.tfvars.

# ── AWS ──────────────────────────────────────
aws_region  = "us-east-1"
environment = "staging"

# ── EC2 ──────────────────────────────────────
instance_type       = "t3.large"
root_volume_size_gb = 40

# Gere com: ssh-keygen -t ed25519 -C "zentriz-genesis-aws" -f ~/.ssh/zentriz-genesis-aws
ssh_public_key_path = "~/.ssh/zentriz-genesis-aws.pub"

# Restrinja para seu IP: curl ifconfig.me
admin_cidr_blocks = ["SEU_IP/32"]

# ── Repositório ───────────────────────────────
github_repo_url    = "https://github.com/zentriz-id/zentriz-genesis.git"
github_repo_branch = "main"

# ── Aplicação ─────────────────────────────────
# Sem claude_api_key: a EC2 acessa Bedrock via IAM instance profile
# Confirme que o modelo está habilitado na sua conta: AWS Console > Bedrock > Model access
bedrock_model_id  = "anthropic.claude-sonnet-4-5"   # ou anthropic.claude-sonnet-4-6
bedrock_region    = "us-east-1"                      # região onde o modelo está habilitado
project_files_dir = "/opt/zentriz-files"

# ── Secrets (sensíveis — nunca commitar) ──────
jwt_secret        = ""          # vazio = gerado automaticamente
pg_password       = "senha-forte-aqui"
genesis_api_token = ""          # vazio = gerado automaticamente

# Credenciais da Conta B (onde está o Bedrock com créditos)
# Crie um IAM user na Conta B com política: bedrock:InvokeModel + InvokeModelWithResponseStream
bedrock_access_key_id     = "AKIA..."
bedrock_secret_access_key = "..."
